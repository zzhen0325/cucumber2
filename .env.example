# Agent model provider priority: Ark -> DeepSeek -> OpenAI
ARK_API_KEY=
ARK_MODEL=doubao-seed-2-0-lite-260428
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

OPENAI_API_KEY=
OPENAI_MODEL=

IMAGE_PROVIDER=seedream
IMAGE_MODEL=
SEEDREAM_ACCESS_KEY_ID=
SEEDREAM_SECRET_ACCESS_KEY=
SEEDREAM_REQ_KEY=jimeng_seedream46_cvtob
SEEDREAM_WIDTH=1024
SEEDREAM_HEIGHT=1024
SEEDREAM_MAX_OUTPUT_IMAGES=4
SEEDREAM_MAX_CONCURRENCY=1
SEEDREAM_STAGGER_MS=800
SEEDREAM_UPSCALE_REQ_KEY=jimeng_i2i_seed3_tilesr_cvtob
SEEDREAM_UPSCALE_RESOLUTION=4k
SEEDREAM_UPSCALE_SCALE=50

# ByteArtist image matting provider. Uses the same ByteArtist credentials below.
IMAGE_MATTING_PROVIDER=byteartist
BYTEARTIST_MATTING_MODEL=image_matting_lemo
BYTEARTIST_MATTING_BLUE=-1
BYTEARTIST_MATTING_GREEN=-1
BYTEARTIST_MATTING_ONLY_MASK=0
BYTEARTIST_MATTING_RED=-1
BYTEARTIST_MATTING_REFINE_MASK=2

# Optional image generation provider:
# IMAGE_PROVIDER=coze
COZE_IMAGE_URL=https://fr8nsskrnk.coze.site/run
COZE_IMAGE_TOKEN=
COZE_IMAGE_MAX_OUTPUT_IMAGES=4
COZE_IMAGE_MAX_INPUT_IMAGES=8
# Optional scalar payloads. Watermark accepts true or false.
COZE_IMAGE_SIZE=
COZE_IMAGE_WATERMARK=
COZE_IMAGE_MODEL=

# Optional ByteArtist/Seed4 image generation provider:
# IMAGE_PROVIDER=byteartist
# Also accepts docs aliases: GATEWAY_BASE_URL, BYTEDANCE_AID,
# BYTEDANCE_APP_KEY, BYTEDANCE_APP_SECRET.
BYTEARTIST_BASE_URL=https://lv-api-lf.ulikecam.com
BYTEARTIST_AID=
BYTEARTIST_APP_KEY=
BYTEARTIST_APP_SECRET=
BYTEARTIST_MODEL=seed4_0407_lemo
BYTEARTIST_WIDTH=1024
BYTEARTIST_HEIGHT=1024
BYTEARTIST_MAX_OUTPUT_IMAGES=4
BYTEARTIST_MAX_INPUT_IMAGES=1
BYTEARTIST_MAX_ATTEMPTS=120
BYTEARTIST_POLL_INTERVAL_MS=1000

# Optional vision model for converting reference images into text prompts when
# the target image model cannot accept image inputs, such as seed4_0407_lemo.
# Defaults to ARK_API_KEY/ARK_MODEL, then OPENAI_API_KEY/OPENAI_MODEL.
IMAGE_REFERENCE_DESCRIPTION_API_KEY=
IMAGE_REFERENCE_DESCRIPTION_BASE_URL=
IMAGE_REFERENCE_DESCRIPTION_MODEL=
IMAGE_REFERENCE_DESCRIPTION_PROVIDER=
ARK_IMAGE_REFERENCE_MODEL=

# Video provider is exposed in /api/health for future generate_video runtime work.
# No video canvas tool is enabled until a provider implementation is wired.
VIDEO_PROVIDER=
VIDEO_MODEL=
VIDEO_API_KEY=
SEEDANCE_ACCESS_KEY_ID=
SEEDANCE_SECRET_ACCESS_KEY=
SEEDANCE_MODEL=

SUPABASE_URL=
SUPABASE_SECRET_KEY=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ASSETS_BUCKET=agent-assets
R2_SKILL_PACKAGES_BUCKET=agent-skill-packages
R2_SIGNED_UPLOAD_TTL_SECONDS=7200
R2_SIGNED_READ_TTL_SECONDS=600

API_PORT=8787
# Local development only. Do not enable in production.
CUCUMBER_DEV_INMEMORY_DB=0
